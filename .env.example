# Chaves de API — nunca commitar valores reais; copie para .env e preencha localmente
#
# Rotação de chaves (até 6 por provedor):
#   GOOGLE_API_KEY_1..6     → até 6 chaves Google AI Studio (quota diária × N definidas)
#   OPENROUTER_API_KEY_1..6 → até 6 chaves OpenRouter (50 req/dia × N definidas)
#   Índices não preenchidos são ignorados — a rotação ocorre só entre as chaves
#   efetivamente definidas (não precisa preencher todas as 6).
#   Fallback: se nenhuma GOOGLE_API_KEY_N existir, usa GOOGLE_API_KEY; idem para OpenRouter.

# ---------------------------------------------------------------------------
# Google AI Studio (gemini, gemini_flash)
# Obter em: https://aistudio.google.com/apikey
# ---------------------------------------------------------------------------
GOOGLE_API_KEY_1=your_google_api_key_member1
GOOGLE_API_KEY_2=your_google_api_key_member2
GOOGLE_API_KEY_3=your_google_api_key_member3
GOOGLE_API_KEY_4=your_google_api_key_member4
# GOOGLE_API_KEY_5=your_google_api_key_member5
# GOOGLE_API_KEY_6=your_google_api_key_member6

# Chave única (compatibilidade / uso individual):
# GOOGLE_API_KEY=your_google_api_key_here

# ---------------------------------------------------------------------------
# OpenRouter (nvidia, nvidia_super, openai_oss — free tier)
# Obter em: https://openrouter.ai/keys
# Limite free: 50 req/dia por conta → 50 × N chaves definidas
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY_1=your_openrouter_api_key_member1
OPENROUTER_API_KEY_2=your_openrouter_api_key_member2
OPENROUTER_API_KEY_3=your_openrouter_api_key_member3
OPENROUTER_API_KEY_4=your_openrouter_api_key_member4
# OPENROUTER_API_KEY_5=your_openrouter_api_key_member5
# OPENROUTER_API_KEY_6=your_openrouter_api_key_member6

# Chave única (compatibilidade / uso individual):
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# ---------------------------------------------------------------------------
# Overrides opcionais de modelo (úteis quando o modelo padrão está indisponível)
# ---------------------------------------------------------------------------
# GEMINI_MODEL_ID=gemini-2.5-flash-lite
# GEMINI_FLASH_MODEL_ID=gemini-2.5-flash
# NVIDIA_MODEL_ID=openrouter/nvidia/nemotron-3-ultra-550b-a55b:free
# NVIDIA_SUPER_MODEL_ID=openrouter/nvidia/nemotron-3-super-120b-a12b:free
# OPENAI_OSS_MODEL_ID=openrouter/openai/gpt-oss-120b:free

# ---------------------------------------------------------------------------
# Backend de modelo ativo:
#   gemini       → gemini-2.5-flash-lite   (T0 zero-shot)           requer GOOGLE_API_KEY_*
#   gemini_flash → gemini-2.5-flash        (pipeline T1)            requer GOOGLE_API_KEY_*
#   nvidia       → nemotron-ultra-550b     (T0 only, modelo grande) requer OPENROUTER_API_KEY_*
#   nvidia_super → nemotron-super-120b     (pipeline T2)            requer OPENROUTER_API_KEY_*
#   openai_oss   → gpt-oss-120b            (pipeline T3)            requer OPENROUTER_API_KEY_*
#   dryrun       → fixture sem API         (padrão para smoke-adk)
# ---------------------------------------------------------------------------
MODEL_BACKEND=dryrun
